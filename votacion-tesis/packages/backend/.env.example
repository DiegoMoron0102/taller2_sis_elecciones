# Configuración del backend de votación
# Copiar a .env y rellenar con valores reales

# Base de datos (Prisma + SQLite)
DATABASE_URL="file:./prisma/dev.db"

# Servidor Express
PORT=4000
CORS_ORIGIN=http://localhost:3000

# JWT para autenticación de administradores
JWT_SECRET=cambiar-por-secreto-largo-y-aleatorio-en-produccion
JWT_EXPIRES_IN=2h

# Blockchain (RPC + direcciones de contratos)
RPC_URL=http://127.0.0.1:8545
ADMIN_PARAMS_ADDRESS=
NULLIFIER_SET_ADDRESS=
BULLETIN_BOARD_ADDRESS=
ESCRUTINIO_ADDRESS=
